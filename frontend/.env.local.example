# Studere — Variables de entorno
# Copiá este archivo a .env.local y completá los valores

# ─── REQUERIDO ────────────────────────────────────────────
# URL del backend Azure Functions
# Local:
NEXT_PUBLIC_BACKEND_URL=http://localhost:7071
# Staging:  NEXT_PUBLIC_BACKEND_URL=https://studere-backend-staging.azurewebsites.net
# Producción: NEXT_PUBLIC_BACKEND_URL=https://studere-backend.azurewebsites.net

# ─── OPCIONAL — Analytics ─────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ─── OPCIONAL — Feature flags ─────────────────────────────
# NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false
# NEXT_PUBLIC_ENABLE_OFFLINE_MODE=false
